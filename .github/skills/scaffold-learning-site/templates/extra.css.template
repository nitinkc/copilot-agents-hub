/* ============================================================
   Learning Guide — Extra CSS
   Compatible with MkDocs Material light (default) + dark (slate)
   ============================================================ */

/* --- Admonition / Details collapsible blocks --- */
details {
  margin: 1.5em 0;
  border-left: 4px solid var(--md-primary-fg-color);
  padding: 0.5em 1em;
  border-radius: 4px;
  background: var(--md-code-bg-color);
}

details summary {
  cursor: pointer;
  font-weight: 600;
  color: var(--md-primary-fg-color);
  user-select: none;
  outline: none;
  padding: 0.5em 0;
  list-style: none;
}

details summary:hover {
  color: var(--md-accent-fg-color);
}

details[open] summary {
  margin-bottom: 0.5em;
}

/* --- Abbreviation hover tooltips --- */
abbr[title] {
  text-decoration: underline dotted var(--md-primary-fg-color);
  cursor: help;
}

/* --- Math block spacing --- */
.arithmatex {
  overflow-x: auto;
  margin: 1.5em 0;
  padding: 0.5em;
}

/* --- Mermaid diagram centering --- */
.mermaid {
  text-align: center;
  margin: 1.5em 0;
}

/* --- Table improvements --- */
.md-typeset table:not([class]) {
  display: table;
  width: 100%;
}

.md-typeset table:not([class]) th {
  background-color: var(--md-primary-fg-color);
  color: var(--md-primary-bg-color);
}

/* --- Level badges in article headers --- */
.badge-beginner { color: #2e7d32; font-weight: bold; }
.badge-intermediate { color: #f57f17; font-weight: bold; }
.badge-advanced { color: #c62828; font-weight: bold; }

/* --- Code block copy button spacing --- */
.md-clipboard {
  margin-top: 0.25em;
}

/* ============================================================
   Dark mode overrides (slate scheme)
   ============================================================ */
[data-md-color-scheme="slate"] details {
  border-left-color: var(--md-accent-fg-color);
}

[data-md-color-scheme="slate"] details summary {
  color: var(--md-accent-fg-color);
}

[data-md-color-scheme="slate"] abbr[title] {
  text-decoration-color: var(--md-accent-fg-color);
}

