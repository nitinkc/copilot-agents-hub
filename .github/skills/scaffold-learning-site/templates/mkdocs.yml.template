theme:
  name: material
  palette:
    - scheme: default
      primary: teal
      accent: blue
      toggle:
        icon: material/weather-night
        name: Switch to dark mode
    - scheme: slate
      primary: teal
      accent: blue
      toggle:
        icon: material/weather-sunny
        name: Switch to light mode
  features:
    - navigation.tabs
    - navigation.sections
    - navigation.top
    - search.highlight
    - search.suggest
    - content.code.copy

site_name: "{TOPIC} — Learning Guide"
site_description: "A progressive learning guide covering {TOPIC} from fundamentals to expert level"
docs_dir: docs
site_dir: site

nav:
  - Home: index.md
  - Getting Started: GETTING_STARTED.md
  - Fundamentals:
      - Core Concepts: fundamentals/01-core-concepts.md
  - Intermediate:
      - Working Together: intermediate/01-working-together.md
  - Advanced:
      - Advanced Patterns: advanced/01-advanced-patterns.md
  - Reference:
      - Cheatsheet: reference/01-cheatsheet.md

plugins:
  - search

markdown_extensions:
  - abbr
  - admonition
  - attr_list
  - def_list
  - footnotes
  - md_in_html
  - toc:
      permalink: true
  - pymdownx.details
  - pymdownx.superfences:
      custom_fences:
        - name: mermaid
          class: mermaid
          format: !!python/name:pymdownx.superfences.fence_code_format
  - pymdownx.highlight:
      anchor_linenums: true
  - pymdownx.inlinehilite
  - pymdownx.snippets:
      base_path: docs
  - pymdownx.tabbed:
      alternate_style: true
  - pymdownx.arithmatex:
      generic: true

extra_javascript:
  - js/mathjax.js
  - https://cdn.jsdelivr.net/npm/mathjax@3/es5/tex-mml-chtml.js
  - https://cdn.jsdelivr.net/npm/mermaid/dist/mermaid.min.js
  - js/mermaid-init.js
  - js/theme-toggle.js

extra_css:
  - css/extra.css

