# Git ignore file for Copilot Agents Hub

# VS Code
.vscode/.history/
.vscode/settings.local.json
.vscode/*.log

# IntelliJ
.idea/
*.iml
*.iws
*.ipr
.jetbrains/.idea/

# OS Files
.DS_Store
Thumbs.db
.AppleDouble
.LSOverride
*.swp
*.swo
*~

# Python
__pycache__/
*.py[cod]
*$py.class
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
.venv/
venv/
ENV/

# Node
node_modules/
npm-debug.log
yarn-error.log

# Build outputs
site/
dist/
target/

# IDE common
.classpath
.project
.settings/

# Logs
*.log
logs/

# Environment files (keep .env.example)
.env
.env.local
.env.*.local

# Temporary files
*.tmp
*.temp
tmp/

# Package manager lockfiles (optional - uncomment if you want to commit them)
# package-lock.json
# yarn.lock
# Pipfile.lock
